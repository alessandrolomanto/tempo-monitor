          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "editorMode": "code",
          "expr": "reth_rpc_server_connections_request_time_seconds{instance=\"faucet\", quantile=\"0.95\"}",
          "legendFormat": "p95",
          "refId": "B"
